@page "/api-test"
@using FhirAugury.DevUi.Services
@using Fhiraugury
@using Google.Protobuf
@inject OrchestratorClient Orchestrator
@inject SourceDirectClient SourceClient
@inject IConfiguration Configuration

<PageTitle>API Tests — FHIR Augury Dev UI</PageTitle>

<h1 class="mb-3"><i class="bi bi-terminal"></i> API Tests</h1>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <label class="form-label fw-semibold">Source</label>
        <select class="form-select" @bind="SelectedSource" @bind:after="OnSourceChanged">
            <option value="">— Select Source —</option>
            @foreach (SourceEndpointInfo ep in _endpoints)
            {
                <option value="@ep.Name">@ep.Name</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label fw-semibold">Protocol</label>
        <div class="btn-group d-block" role="group">
            <button type="button"
                    class="btn @(_protocol == "grpc" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => _protocol = "grpc"'>
                <i class="bi bi-hdd-network"></i> gRPC
            </button>
            <button type="button"
                    class="btn @(_protocol == "http" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => _protocol = "http"'>
                <i class="bi bi-globe"></i> HTTP
            </button>
        </div>
    </div>
    <div class="col-md-3">
        <label class="form-label fw-semibold">API</label>
        <select class="form-select" @bind="SelectedApi">
            <option value="">— Select API —</option>
            @if (_isOrchestrator)
            {
                <option value="unified-search">Unified Search</option>
                <option value="find-related">Find Related</option>
                <option value="get-xref">Get Cross-References</option>
                <option value="get-item">Get Item (proxied)</option>
                <option value="get-snapshot">Get Snapshot (proxied)</option>
                <option value="get-content">Get Content (proxied)</option>
                <option value="get-services-status">Services Status</option>
                <option value="get-stats">Aggregate Stats</option>
                <option value="rebuild-index">Rebuild Index</option>
                <option value="trigger-sync">Trigger Sync</option>
            }
            else
            {
                <option value="search">Search</option>
                <option value="get-item">GetItem</option>
                <option value="get-related">GetRelated</option>
                <option value="get-snapshot">GetSnapshot</option>
                <option value="get-content">GetContent</option>
                <option value="get-stats">GetStats</option>
                <option value="health-check">HealthCheck</option>
            }
        </select>
    </div>
</div>

@if (_selectedEndpoint is not null && !string.IsNullOrEmpty(SelectedApi))
{
    <div class="mb-3 text-body-secondary small">
        <i class="bi bi-info-circle"></i>
        @if (_protocol == "grpc")
        {
            <span>Target: <code>@_selectedEndpoint.GrpcAddress</code> (gRPC)</span>
        }
        else
        {
            <span>Target: <code>@_selectedEndpoint.HttpAddress</code> (HTTP)</span>
        }
    </div>

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-play-circle"></i> @ApiDisplayName(SelectedApi)
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                @if (NeedsQuery)
                {
                    <div class="col-md-4">
                        <label class="form-label">Query</label>
                        <input type="text" class="form-control" @bind="_queryInput"
                               @bind:event="oninput" placeholder="e.g. patient resource" />
                    </div>
                }
                @if (NeedsId)
                {
                    <div class="col-md-4">
                        <label class="form-label">ID</label>
                        <input type="text" class="form-control" @bind="_idInput"
                               @bind:event="oninput" placeholder="@IdPlaceholder" />
                    </div>
                }
                @if (NeedsLimit)
                {
                    <div class="col-md-2">
                        <label class="form-label">Limit</label>
                        <input type="number" class="form-control" @bind="_limitInput" min="1" max="200" />
                    </div>
                }
                @if (NeedsSourceFilter)
                {
                    <div class="col-md-2">
                        <label class="form-label">Target Source</label>
                        <select class="form-select" @bind="_sourceFilterInput">
                            <option value="">— Select —</option>
                            @foreach (SourceEndpointInfo ep in _endpoints.Where(e => e.Name != "orchestrator"))
                            {
                                <option value="@ep.Name.ToLowerInvariant()">@ep.Name</option>
                            }
                        </select>
                    </div>
                }
                @if (NeedsType)
                {
                    <div class="col-md-2">
                        <label class="form-label">Type</label>
                        <select class="form-select" @bind="_typeInput">
                            @if (SelectedApi == "rebuild-index")
                            {
                                <option value="all">all</option>
                                <option value="bm25">bm25</option>
                                <option value="fts">fts</option>
                                <option value="cross-refs">cross-refs</option>
                                <option value="lookup-tables">lookup-tables</option>
                            }
                            else
                            {
                                <option value="incremental">incremental</option>
                                <option value="full">full</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button class="btn btn-primary d-block" @onclick="ExecuteAsync"
                            disabled="@(_running || !CanExecute)">
                        @if (_running)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <i class="bi bi-play-fill"></i>
                        }
                        Go
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_error is not null)
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> <strong>Error:</strong> @_error
    </div>
}

@if (_resultJson is not null)
{
    <div class="mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
            <h5 class="mb-0">
                <i class="bi bi-check-circle text-success"></i> Response
            </h5>
            <div class="d-flex align-items-center gap-2">
                @if (_requestInfo is not null)
                {
                    <span class="badge bg-secondary">@_requestInfo</span>
                }
                @if (_elapsedMs.HasValue)
                {
                    <span class="badge bg-info">@(_elapsedMs)ms</span>
                }
                @if (_searchResults is not null)
                {
                    <span class="badge bg-info">@_searchResults.TotalResults results</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleRaw">
                        <i class="bi @(_showRaw ? "bi-table" : "bi-code-slash")"></i>
                        @(_showRaw ? "Table View" : "Raw JSON")
                    </button>
                }
            </div>
        </div>

        @if (_searchResults is not null && !_showRaw)
        {
            @if (_searchResults.Results.Count == 0)
            {
                <div class="alert alert-info">No results found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Source</th>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Content Type</th>
                                <th class="text-end">Score</th>
                                <th>Snippet</th>
                                <th>URL</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (SearchResultItem item in _searchResults.Results)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@item.Source</span></td>
                                    <td><code>@item.Id</code></td>
                                    <td title="@item.Title">@Truncate(item.Title, 60)</td>
                                    <td><code>@item.ContentType</code></td>
                                    <td class="text-end fw-semibold">@item.Score.ToString("F2")</td>
                                    <td title="@item.Snippet">@Truncate(item.Snippet, 50)</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Url))
                                        {
                                            <a href="@item.Url" target="_blank" rel="noopener"
                                               class="btn btn-sm btn-outline-primary" title="Open in new tab">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <pre class="bg-body-secondary border rounded p-3 overflow-auto"
                 style="max-height: 600px;"><code>@_resultJson</code></pre>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "source")]
    public string? DefaultSource { get; set; }

    private string SelectedSource { get; set; } = "";
    private string SelectedApi { get; set; } = "";

    private string _protocol = "grpc";
    private string _queryInput = "";
    private string _idInput = "";
    private int _limitInput = 20;
    private string _sourceFilterInput = "";
    private string _typeInput = "all";

    private bool _running;
    private string? _error;
    private string? _resultJson;
    private string? _requestInfo;
    private long? _elapsedMs;
    private bool _showRaw;

    // Typed result for table rendering (gRPC Search/GetRelated only)
    private SearchResponse? _searchResults;

    private List<SourceEndpointInfo> _endpoints = [];
    private SourceEndpointInfo? _selectedEndpoint =>
        _endpoints.FirstOrDefault(e => string.Equals(e.Name, SelectedSource, StringComparison.OrdinalIgnoreCase));

    private bool _isOrchestrator => string.Equals(SelectedSource, "orchestrator", StringComparison.OrdinalIgnoreCase);

    // ── Input field visibility ───────────────────────────────────

    private bool NeedsQuery => _isOrchestrator
        ? SelectedApi == "unified-search"
        : SelectedApi == "search";

    private bool NeedsId => _isOrchestrator
        ? SelectedApi is "find-related" or "get-xref" or "get-item" or "get-snapshot" or "get-content"
        : SelectedApi is "get-item" or "get-related" or "get-snapshot" or "get-content";

    private bool NeedsLimit => _isOrchestrator
        ? SelectedApi is "unified-search" or "find-related"
        : SelectedApi is "search" or "get-related";

    private bool NeedsSourceFilter => _isOrchestrator
        && SelectedApi is "find-related" or "get-xref" or "get-item" or "get-snapshot" or "get-content";

    private bool NeedsType => _isOrchestrator
        && SelectedApi is "rebuild-index" or "trigger-sync";

    private string IdPlaceholder => (_isOrchestrator ? _sourceFilterInput : SelectedSource)?.ToLowerInvariant() switch
    {
        "jira" => "e.g. FHIR-55001",
        "github" => "e.g. HL7/fhir#4006",
        "zulip" => "e.g. 12345",
        "confluence" => "e.g. 12345",
        _ => "e.g. FHIR-55001",
    };

    private bool CanExecute =>
        _selectedEndpoint is not null
        && !string.IsNullOrEmpty(SelectedApi)
        && (!NeedsQuery || !string.IsNullOrWhiteSpace(_queryInput))
        && (!NeedsId || !string.IsNullOrWhiteSpace(_idInput))
        && (!NeedsSourceFilter || !string.IsNullOrWhiteSpace(_sourceFilterInput));

    // ── Initialization ───────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ServiceEndpointsResponse endpoints = await Orchestrator.GetServiceEndpointsAsync();
            _endpoints = endpoints.Endpoints
                .Where(e => e.Enabled)
                .Select(e => new SourceEndpointInfo(e.Name, e.GrpcAddress, e.HttpAddress))
                .OrderBy(e => e.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch
        {
            // Fall back to configured defaults when orchestrator is unreachable
            IConfigurationSection sourcesSection = Configuration.GetSection("DevUi:Sources");
            List<SourceEndpointInfo> fallback = [];
            foreach (IConfigurationSection child in sourcesSection.GetChildren())
            {
                string name = child.Key;
                string grpc = child["GrpcAddress"] ?? "";
                string http = child["HttpAddress"] ?? "";
                if (!string.IsNullOrEmpty(grpc))
                    fallback.Add(new SourceEndpointInfo(name, grpc, http));
            }
            _endpoints = fallback.OrderBy(e => e.Name, StringComparer.OrdinalIgnoreCase).ToList();
        }

        // Always inject orchestrator at the top of the list
        _endpoints.Insert(0, new SourceEndpointInfo("orchestrator", Orchestrator.GrpcAddress, Orchestrator.HttpAddress));

        if (!string.IsNullOrEmpty(DefaultSource))
        {
            SelectedSource = DefaultSource;
        }
    }

    // ── Execution ────────────────────────────────────────────────

    private async Task ExecuteAsync()
    {
        _running = true;
        _error = null;
        _resultJson = null;
        _requestInfo = null;
        _elapsedMs = null;
        _searchResults = null;
        _showRaw = false;
        StateHasChanged();

        try
        {
            if (_isOrchestrator)
            {
                if (_protocol == "grpc")
                    await ExecuteOrchestratorGrpcAsync();
                else
                    await ExecuteOrchestratorHttpAsync();
            }
            else
            {
                SourceEndpointInfo endpoint = _selectedEndpoint!;

                if (_protocol == "grpc")
                    await ExecuteGrpcAsync(endpoint);
                else
                    await ExecuteHttpAsync(endpoint);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _running = false;
        }
    }

    private async Task ExecuteGrpcAsync(SourceEndpointInfo endpoint)
    {
        string grpcAddr = endpoint.GrpcAddress;
        string rpcName;
        IMessage response;
        long elapsed;

        switch (SelectedApi)
        {
            case "search":
                rpcName = "SourceService/Search";
                (response, elapsed) = await SourceClient.SearchGrpcAsync(grpcAddr, _queryInput, _limitInput);
                _searchResults = (SearchResponse)response;
                break;
            case "get-item":
                rpcName = "SourceService/GetItem";
                (response, elapsed) = await SourceClient.GetItemGrpcAsync(grpcAddr, _idInput);
                break;
            case "get-related":
                rpcName = "SourceService/GetRelated";
                (response, elapsed) = await SourceClient.GetRelatedGrpcAsync(grpcAddr, _idInput, _limitInput);
                _searchResults = (SearchResponse)response;
                break;
            case "get-snapshot":
                rpcName = "SourceService/GetSnapshot";
                (response, elapsed) = await SourceClient.GetSnapshotGrpcAsync(grpcAddr, _idInput);
                break;
            case "get-content":
                rpcName = "SourceService/GetContent";
                (response, elapsed) = await SourceClient.GetContentGrpcAsync(grpcAddr, _idInput);
                break;
            case "get-stats":
                rpcName = "SourceService/GetStats";
                (response, elapsed) = await SourceClient.GetStatsGrpcAsync(grpcAddr);
                break;
            case "health-check":
                rpcName = "SourceService/HealthCheck";
                (response, elapsed) = await SourceClient.HealthCheckGrpcAsync(grpcAddr);
                break;
            default:
                return;
        }

        _resultJson = SourceDirectClient.FormatAsJson(response);
        _requestInfo = $"gRPC {rpcName} → {grpcAddr}";
        _elapsedMs = elapsed;
    }

    private async Task ExecuteHttpAsync(SourceEndpointInfo endpoint)
    {
        string httpBase = endpoint.HttpAddress;
        string url;
        string json;
        long elapsed;

        switch (SelectedApi)
        {
            case "search":
                (url, json, elapsed) = await SourceClient.SearchHttpAsync(httpBase, _queryInput, _limitInput);
                break;
            case "get-item":
                (url, json, elapsed) = await SourceClient.GetItemHttpAsync(httpBase, endpoint.Name, _idInput);
                break;
            case "get-related":
                (url, json, elapsed) = await SourceClient.GetRelatedHttpAsync(httpBase, endpoint.Name, _idInput, _limitInput);
                break;
            case "get-snapshot":
                (url, json, elapsed) = await SourceClient.GetSnapshotHttpAsync(httpBase, endpoint.Name, _idInput);
                break;
            case "get-content":
                (url, json, elapsed) = await SourceClient.GetContentHttpAsync(httpBase, endpoint.Name, _idInput);
                break;
            case "get-stats":
                (url, json, elapsed) = await SourceClient.GetStatsHttpAsync(httpBase);
                break;
            case "health-check":
                (url, json, elapsed) = await SourceClient.HealthCheckHttpAsync(httpBase);
                break;
            default:
                return;
        }

        _resultJson = json;
        _requestInfo = $"GET {url}";
        _elapsedMs = elapsed;
    }

    // ── Orchestrator gRPC execution ─────────────────────────────

    private async Task ExecuteOrchestratorGrpcAsync()
    {
        string rpcName;
        IMessage response;
        long elapsed;

        switch (SelectedApi)
        {
            case "unified-search":
                rpcName = "OrchestratorService/UnifiedSearch";
                (response, elapsed) = await Orchestrator.UnifiedSearchGrpcAsync(_queryInput, _limitInput);
                _searchResults = (SearchResponse)response;
                break;
            case "find-related":
                rpcName = "OrchestratorService/FindRelated";
                (response, elapsed) = await Orchestrator.FindRelatedGrpcAsync(_sourceFilterInput, _idInput, _limitInput);
                break;
            case "get-xref":
                rpcName = "OrchestratorService/GetCrossReferences";
                (response, elapsed) = await Orchestrator.GetCrossReferencesGrpcAsync(_sourceFilterInput, _idInput);
                break;
            case "get-item":
                rpcName = "OrchestratorService/GetItem";
                (response, elapsed) = await Orchestrator.GetItemGrpcAsync(_sourceFilterInput, _idInput);
                break;
            case "get-snapshot":
                rpcName = "OrchestratorService/GetSnapshot";
                (response, elapsed) = await Orchestrator.GetSnapshotGrpcAsync(_sourceFilterInput, _idInput);
                break;
            case "get-content":
                rpcName = "OrchestratorService/GetContent";
                (response, elapsed) = await Orchestrator.GetContentGrpcAsync(_sourceFilterInput, _idInput);
                break;
            case "get-services-status":
                rpcName = "OrchestratorService/GetServicesStatus";
                (response, elapsed) = await Orchestrator.GetServicesStatusGrpcAsync();
                break;
            case "get-stats":
                // Stats is HTTP-only; fall back to HTTP
                (string url, string json, long httpElapsed) = await Orchestrator.GetStatsHttpAsync();
                _resultJson = json;
                _requestInfo = $"GET {url} (HTTP-only)";
                _elapsedMs = httpElapsed;
                return;
            case "rebuild-index":
                rpcName = "OrchestratorService/RebuildIndex";
                (response, elapsed) = await Orchestrator.RebuildIndexGrpcAsync(_typeInput);
                break;
            case "trigger-sync":
                rpcName = "OrchestratorService/TriggerSync";
                (response, elapsed) = await Orchestrator.TriggerSyncGrpcAsync(_typeInput);
                break;
            default:
                return;
        }

        _resultJson = OrchestratorClient.FormatAsJson(response);
        _requestInfo = $"gRPC {rpcName} → {Orchestrator.GrpcAddress}";
        _elapsedMs = elapsed;
    }

    private async Task ExecuteOrchestratorHttpAsync()
    {
        string url;
        string json;
        long elapsed;

        switch (SelectedApi)
        {
            case "unified-search":
                (url, json, elapsed) = await Orchestrator.UnifiedSearchHttpAsync(_queryInput, _limitInput);
                break;
            case "find-related":
                (url, json, elapsed) = await Orchestrator.FindRelatedHttpAsync(_sourceFilterInput, _idInput, _limitInput);
                break;
            case "get-xref":
                (url, json, elapsed) = await Orchestrator.GetCrossReferencesHttpAsync(_sourceFilterInput, _idInput);
                break;
            case "get-item":
                (url, json, elapsed) = await Orchestrator.GetItemHttpAsync(_sourceFilterInput, _idInput);
                break;
            case "get-snapshot":
                (url, json, elapsed) = await Orchestrator.GetSnapshotHttpAsync(_sourceFilterInput, _idInput);
                break;
            case "get-content":
                (url, json, elapsed) = await Orchestrator.GetContentHttpAsync(_sourceFilterInput, _idInput);
                break;
            case "get-services-status":
                (url, json, elapsed) = await Orchestrator.GetServicesStatusHttpAsync();
                break;
            case "get-stats":
                (url, json, elapsed) = await Orchestrator.GetStatsHttpAsync();
                break;
            case "rebuild-index":
                (url, json, elapsed) = await Orchestrator.RebuildIndexHttpAsync(_typeInput);
                break;
            case "trigger-sync":
                (url, json, elapsed) = await Orchestrator.TriggerSyncHttpAsync(_typeInput);
                break;
            default:
                return;
        }

        _resultJson = json;
        _requestInfo = $"{(SelectedApi is "rebuild-index" or "trigger-sync" ? "POST" : "GET")} {url}";
        _elapsedMs = elapsed;
    }

    // ── Helpers ──────────────────────────────────────────────────

    private void OnSourceChanged()
    {
        SelectedApi = "";
        _sourceFilterInput = "";
        _typeInput = "all";
        _error = null;
        _resultJson = null;
        _requestInfo = null;
        _elapsedMs = null;
        _searchResults = null;
    }

    private void ToggleRaw() => _showRaw = !_showRaw;

    private static string ApiDisplayName(string api) => api switch
    {
        "search" => "Search",
        "get-item" => "Get Item",
        "get-related" => "Get Related",
        "get-snapshot" => "Get Snapshot",
        "get-content" => "Get Content",
        "get-stats" => "Get Stats",
        "health-check" => "Health Check",
        "unified-search" => "Unified Search",
        "find-related" => "Find Related",
        "get-xref" => "Get Cross-References",
        "get-services-status" => "Services Status",
        "rebuild-index" => "Rebuild Index",
        "trigger-sync" => "Trigger Sync",
        _ => api,
    };

    private static string Truncate(string text, int maxLength) =>
        string.IsNullOrEmpty(text)
            ? ""
            : text.Length <= maxLength
                ? text
                : string.Concat(text.AsSpan(0, maxLength), "…");

    private sealed record SourceEndpointInfo(string Name, string GrpcAddress, string HttpAddress);
}

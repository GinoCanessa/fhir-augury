@page "/api-test"
@using FhirAugury.DevUi.Services
@using FhirAugury.DevUi.Services.ApiCatalog
@using System.Net.Http
@using System.Text.Json
@using Microsoft.JSInterop
@inject OrchestratorClient Orchestrator
@inject ApiInvoker Invoker
@inject OpenApiCatalogClient OpenApi
@inject IConfiguration Configuration
@inject IJSRuntime JS

<PageTitle>API Tests — FHIR Augury Dev UI</PageTitle>

<h1 class="mb-3"><i class="bi bi-terminal"></i> API Tests</h1>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <label class="form-label fw-semibold">Source</label>
        <select class="form-select" @bind="SelectedSource" @bind:after="OnSourceChangedAsync">
            <option value="">— Select Source —</option>
            @foreach (SourceEndpointInfo ep in _endpoints)
            {
                <option value="@ep.Name">@ep.Name</option>
            }
        </select>
    </div>
    <div class="col-md-5">
        <label class="form-label fw-semibold">API</label>
        <select class="form-select" @bind="SelectedApiId" @bind:after="OnApiChangedAsync">
            <option value="">— Select API —</option>
            @foreach (IGrouping<string, ApiEndpointDescriptor> grp in _catalog.GroupBy(d => d.Group).OrderBy(g => g.Key))
            {
                <optgroup label="@grp.Key">
                    @foreach (ApiEndpointDescriptor d in grp.OrderBy(x => x.DisplayName))
                    {
                        <option value="@d.Id">@d.DisplayName</option>
                    }
                </optgroup>
            }
        </select>
    </div>
</div>

@if (_descriptor is not null)
{
    <div class="mb-3 text-body-secondary small">
        <i class="bi bi-info-circle"></i>
        <span>Target: <code>@_selectedEndpoint?.Address</code> (HTTP) — <strong>@_descriptor.Method.Method</strong> <code>@_descriptor.PathTemplate</code></span>
        @if (_descriptor.Destructive)
        {
            <span class="badge bg-danger ms-2"><i class="bi bi-exclamation-triangle"></i> destructive</span>
        }
    </div>

    <div class="card mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-play-circle"></i> @_descriptor.DisplayName
        </div>
        <div class="card-body">
            @if (_descriptor.Parameters.Count == 0)
            {
                <p class="text-body-secondary mb-0">This endpoint takes no parameters.</p>
            }
            else
            {
                <div class="row g-3">
                    @foreach (ApiParameter p in _descriptor.Parameters)
                    {
                        <div class="@ColumnClass(p)">
                            <label class="form-label">
                                @p.Name
                                @if (p.Required)
                                {
                                    <span class="text-danger">*</span>
                                }
                                <span class="badge bg-light text-body-secondary border">@p.Kind</span>
                            </label>
                            @if (p.ValueType == ApiParameterValueType.Bool)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           checked="@(GetBool(p))"
                                           @onchange="e => SetBool(p, e)" />
                                </div>
                            }
                            else if (p.ValueType == ApiParameterValueType.Json)
                            {
                                <textarea class="form-control font-monospace" rows="6"
                                          @oninput="e => OnValueInput(p.Name, e)"
                                          @bind="_values[p.Name]"></textarea>
                            }
                            else
                            {
                                <input class="form-control"
                                       type="@(p.ValueType is ApiParameterValueType.Int or ApiParameterValueType.Long or ApiParameterValueType.Double ? "number" : "text")"
                                       placeholder="@(p.Placeholder ?? p.DefaultValue ?? "")"
                                       @oninput="e => OnValueInput(p.Name, e)"
                                       @bind="_values[p.Name]" />
                            }
                            @if (!string.IsNullOrEmpty(p.HelpText))
                            {
                                <div class="form-text">@p.HelpText</div>
                            }
                        </div>
                    }
                </div>
            }
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="OnInvokeClickedAsync" disabled="@_running">
                    @if (_running)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-play-fill"></i>
                    }
                    Go
                </button>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-semibold"><i class="bi bi-eye"></i> Request preview</div>
        <div class="card-body">
            @if (_previewError is not null)
            {
                <div class="text-danger small mb-2">@_previewError</div>
            }
            <div><span class="badge bg-secondary">@(_preview?.Method.Method ?? _descriptor.Method.Method)</span>
                <code>@(_preview?.Url ?? "(invalid)")</code></div>
            @if (!string.IsNullOrEmpty(_preview?.JsonBody))
            {
                <pre class="bg-body-secondary border rounded p-2 mt-2 mb-0 small overflow-auto"
                     style="max-height: 240px;"><code>@_preview.JsonBody</code></pre>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-semibold d-flex align-items-center">
            <button class="btn btn-link p-0 me-2 text-decoration-none" type="button"
                    @onclick="ToggleOpenApiPanelAsync" aria-expanded="@_openApiOpen">
                <i class="bi @(_openApiOpen ? "bi-chevron-down" : "bi-chevron-right")"></i>
                OpenAPI / schema
            </button>
            @if (_openApiInfo?.OperationId is not null)
            {
                <code class="ms-2 small text-body-secondary">@_openApiInfo.OperationId</code>
            }
            <button class="btn btn-sm btn-outline-secondary ms-auto" type="button"
                    @onclick="RefreshOpenApiAsync" disabled="@_openApiLoading"
                    title="Re-fetch openapi.json from this source">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
        @if (_openApiOpen)
        {
            <div class="card-body">
                @if (_openApiLoading)
                {
                    <div class="text-body-secondary small">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        Fetching <code>@(_selectedEndpoint?.Address.TrimEnd('/'))/api/v1/openapi.json</code>…
                    </div>
                }
                else if (_openApiError is not null)
                {
                    <div class="text-danger small">@_openApiError</div>
                }
                else if (_openApiInfo is null)
                {
                    <div class="text-body-secondary small">
                        No matching operation found for
                        <code>@_descriptor.Method.Method @_descriptor.PathTemplate</code> in this source's
                        OpenAPI document.
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(_openApiInfo.Summary))
                    {
                        <div class="mb-2"><strong>Summary:</strong> @_openApiInfo.Summary</div>
                    }
                    @if (!string.IsNullOrEmpty(_openApiInfo.Description))
                    {
                        <div class="mb-2 small text-body-secondary">@_openApiInfo.Description</div>
                    }
                    @if (!string.IsNullOrEmpty(_openApiInfo.RequestBodyJson))
                    {
                        <div class="fw-semibold small mb-1">Request body</div>
                        <pre class="bg-body-secondary border rounded p-2 mb-2 small overflow-auto"
                             style="max-height: 320px;"><code>@_openApiInfo.RequestBodyJson</code></pre>
                    }
                    @if (!string.IsNullOrEmpty(_openApiInfo.ParametersJson))
                    {
                        <div class="fw-semibold small mb-1">Parameters</div>
                        <pre class="bg-body-secondary border rounded p-2 mb-0 small overflow-auto"
                             style="max-height: 240px;"><code>@_openApiInfo.ParametersJson</code></pre>
                    }
                    @if (string.IsNullOrEmpty(_openApiInfo.RequestBodyJson)
                        && string.IsNullOrEmpty(_openApiInfo.ParametersJson))
                    {
                        <div class="text-body-secondary small">No parameters or request body documented.</div>
                    }
                }
            </div>
        }
    </div>
}

@if (_descriptor?.Destructive == true && _confirmOpen)
{
    <div class="modal show d-block" tabindex="-1" role="dialog"
         style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Confirm destructive action</h5>
                </div>
                <div class="modal-body">
                    <p>You are about to invoke <strong>@_descriptor.DisplayName</strong>
                       on <code>@_selectedEndpoint?.Address</code>.</p>
                    <p class="mb-0"><strong>@_descriptor.Method.Method</strong> <code>@(_preview?.Url ?? _descriptor.PathTemplate)</code></p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _confirmOpen = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmAndExecuteAsync">
                        <i class="bi bi-trash"></i> Proceed
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_result is not null)
{
    <div class="mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
            <h5 class="mb-0">
                <i class="bi @(_result.IsSuccess ? "bi-check-circle text-success" : "bi-x-octagon text-danger")"></i> Response
            </h5>
            <div class="d-flex align-items-center gap-2">
                <span class="badge @(_result.IsSuccess ? "bg-success" : "bg-danger")">@_result.StatusCode</span>
                <span class="badge bg-secondary">@_result.Method.Method @_result.Url</span>
                <span class="badge bg-info">@_result.ElapsedMs ms</span>
                @if (_parsedResults is not null)
                {
                    <span class="badge bg-info">@_parsedTotalResults results</span>
                }
                @if (_parsedCrossRefs is not null)
                {
                    <span class="badge bg-info">@_parsedCrossRefs.Count references</span>
                }
                @if (_parsedResults is not null || _parsedCrossRefs is not null)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleRaw">
                        <i class="bi @(_showRaw ? "bi-table" : "bi-code-slash")"></i>
                        @(_showRaw ? "Table View" : "Raw JSON")
                    </button>
                }
            </div>
        </div>

        @if (_parsedResults is not null && !_showRaw)
        {
            @if (_parsedResults.Count == 0)
            {
                <div class="alert alert-info">No results found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Source</th>
                                <th>ID</th>
                                <th>Title</th>
                                <th class="text-end">Score</th>
                                <th>Snippet</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (ParsedSearchResult item in _parsedResults)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@item.Source</span></td>
                                    <td><code>@item.Id</code></td>
                                    <td title="@item.Title">@Truncate(item.Title, 60)</td>
                                    <td class="text-end fw-semibold">@item.Score.ToString("F2")</td>
                                    <td title="@item.Snippet">@Truncate(item.Snippet ?? "", 50)</td>
                                    <td>
                                        <a href="@ItemViewerUrl.For(item.Source, item.Id)"
                                           class="btn btn-sm btn-outline-info" title="View locally cached item">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (!string.IsNullOrEmpty(item.Url))
                                        {
                                            <a href="@item.Url" target="_blank" rel="noopener"
                                               class="btn btn-sm btn-outline-secondary ms-1" title="Open in external system">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else if (_parsedCrossRefs is not null && !_showRaw)
        {
            @if (_parsedCrossRefs.Count == 0)
            {
                <div class="alert alert-info">No cross-references found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Source</th>
                                <th>Source ID</th>
                                <th>Link</th>
                                <th>Target</th>
                                <th>Target ID</th>
                                <th>Title</th>
                                <th>Score</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (ParsedCrossRef item in _parsedCrossRefs)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@item.SourceType</span></td>
                                    <td><code>@item.SourceId</code></td>
                                    <td><span class="badge bg-primary">@item.LinkType</span></td>
                                    <td><span class="badge bg-secondary">@item.TargetType</span></td>
                                    <td><code>@item.TargetId</code></td>
                                    <td title="@item.TargetTitle">@Truncate(item.TargetTitle ?? "", 60)</td>
                                    <td>@item.Score.ToString("F2")</td>
                                    <td>
                                        <a href="@ItemViewerUrl.For(item.ViewType, item.ViewId)"
                                           class="btn btn-sm btn-outline-info" title="View locally cached item">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (!string.IsNullOrEmpty(item.TargetUrl))
                                        {
                                            <a href="@item.TargetUrl" target="_blank" rel="noopener"
                                               class="btn btn-sm btn-outline-secondary ms-1" title="Open in external system">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <pre class="bg-body-secondary border rounded p-3 overflow-auto"
                 style="max-height: 600px;"><code>@_result.ResponseBody</code></pre>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "source")]
    public string? DefaultSource { get; set; }

    private string SelectedSource { get; set; } = "";
    private string SelectedApiId { get; set; } = "";

    private List<SourceEndpointInfo> _endpoints = [];
    private IReadOnlyList<ApiEndpointDescriptor> _catalog = [];
    private ApiEndpointDescriptor? _descriptor;
    private SourceEndpointInfo? _selectedEndpoint =>
        _endpoints.FirstOrDefault(e => string.Equals(e.Name, SelectedSource, StringComparison.OrdinalIgnoreCase));

    private Dictionary<string, string?> _values = new(StringComparer.OrdinalIgnoreCase);

    private ApiBuiltRequest? _preview;
    private string? _previewError;

    private bool _running;
    private bool _confirmOpen;

    private ApiInvocationResult? _result;
    private bool _showRaw;
    private List<ParsedSearchResult>? _parsedResults;
    private int _parsedTotalResults;
    private List<ParsedCrossRef>? _parsedCrossRefs;

    private bool _restoredFromStorage;

    // OpenAPI / schema panel state
    private bool _openApiOpen;
    private bool _openApiLoading;
    private string? _openApiError;
    private OpenApiOperationInfo? _openApiInfo;

    protected override Task OnInitializedAsync()
    {
        IConfigurationSection sourcesSection = Configuration.GetSection("DevUi:Sources");
        List<SourceEndpointInfo> sources = [];
        foreach (IConfigurationSection child in sourcesSection.GetChildren())
        {
            string name = child.Key;
            string address = child["Address"] ?? "";
            if (!string.IsNullOrEmpty(address))
                sources.Add(new SourceEndpointInfo(name, address));
        }
        _endpoints = sources.OrderBy(e => e.Name, StringComparer.OrdinalIgnoreCase).ToList();
        _endpoints.Insert(0, new SourceEndpointInfo("orchestrator", Orchestrator.Address));

        if (!string.IsNullOrEmpty(DefaultSource))
        {
            SelectedSource = DefaultSource;
            _catalog = SourceApiCatalog.GetCatalog(SelectedSource);
        }
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _restoredFromStorage) return;
        _restoredFromStorage = true;

        try
        {
            string? storedSource = await JS.InvokeAsync<string?>("sessionStorage.getItem", "apitest.source");
            string? storedApi = await JS.InvokeAsync<string?>("sessionStorage.getItem", "apitest.api");

            if (string.IsNullOrEmpty(SelectedSource) && !string.IsNullOrEmpty(storedSource)
                && _endpoints.Any(e => e.Name == storedSource))
            {
                SelectedSource = storedSource;
                _catalog = SourceApiCatalog.GetCatalog(SelectedSource);
            }

            if (!string.IsNullOrEmpty(storedApi) && _catalog.Any(d => d.Id == storedApi))
            {
                SelectedApiId = storedApi;
                _descriptor = _catalog.First(d => d.Id == SelectedApiId);
                await RestoreValuesAsync();
                RebuildPreview();
            }

            StateHasChanged();
        }
        catch
        {
            // sessionStorage not available (prerender or non-browser host) — ignore
        }
    }

    private async Task RestoreValuesAsync()
    {
        if (_descriptor is null) return;
        _values = SeedValues(_descriptor);
        string key = $"apitest.values.{SelectedSource}.{SelectedApiId}";
        try
        {
            string? json = await JS.InvokeAsync<string?>("sessionStorage.getItem", key);
            if (string.IsNullOrEmpty(json)) return;
            Dictionary<string, string?>? saved = JsonSerializer.Deserialize<Dictionary<string, string?>>(json);
            if (saved is null) return;
            foreach (KeyValuePair<string, string?> kv in saved)
            {
                if (_values.ContainsKey(kv.Key))
                    _values[kv.Key] = kv.Value;
            }
        }
        catch { /* ignore */ }
    }

    private async Task PersistValuesAsync()
    {
        if (_descriptor is null) return;
        string key = $"apitest.values.{SelectedSource}.{SelectedApiId}";
        try
        {
            string json = JsonSerializer.Serialize(_values);
            await JS.InvokeVoidAsync("sessionStorage.setItem", key, json);
        }
        catch { /* ignore */ }
    }

    private async Task OnSourceChangedAsync()
    {
        _catalog = SourceApiCatalog.GetCatalog(SelectedSource);
        SelectedApiId = "";
        _descriptor = null;
        _values = new(StringComparer.OrdinalIgnoreCase);
        _preview = null;
        _previewError = null;
        ClearResult();
        ResetOpenApiPanel();
        try { await JS.InvokeVoidAsync("sessionStorage.setItem", "apitest.source", SelectedSource); }
        catch { }
    }

    private async Task OnApiChangedAsync()
    {
        _descriptor = _catalog.FirstOrDefault(d => d.Id == SelectedApiId);
        _values = _descriptor is null ? new(StringComparer.OrdinalIgnoreCase) : SeedValues(_descriptor);
        ClearResult();
        ResetOpenApiPanel();
        if (_descriptor is not null)
            await RestoreValuesAsync();
        RebuildPreview();
        if (_openApiOpen && _descriptor is not null)
            await LoadOpenApiAsync(forceRefresh: false);
        try { await JS.InvokeVoidAsync("sessionStorage.setItem", "apitest.api", SelectedApiId); }
        catch { }
    }

    private void ResetOpenApiPanel()
    {
        _openApiInfo = null;
        _openApiError = null;
        _openApiLoading = false;
    }

    private async Task ToggleOpenApiPanelAsync()
    {
        _openApiOpen = !_openApiOpen;
        if (_openApiOpen && _descriptor is not null && _openApiInfo is null && _openApiError is null)
        {
            await LoadOpenApiAsync(forceRefresh: false);
        }
    }

    private async Task RefreshOpenApiAsync()
    {
        OpenApi.Clear();
        await LoadOpenApiAsync(forceRefresh: true);
    }

    private async Task LoadOpenApiAsync(bool forceRefresh)
    {
        if (_descriptor is null || _selectedEndpoint is null) return;
        _openApiLoading = true;
        _openApiError = null;
        _openApiInfo = null;
        StateHasChanged();
        try
        {
            string clientName = string.Equals(SelectedSource, SourceApiCatalog.Orchestrator,
                StringComparison.OrdinalIgnoreCase) ? "orchestrator" : "source-direct";
            System.Text.Json.JsonDocument doc = await OpenApi.GetOrFetchAsync(clientName, _selectedEndpoint.Address);
            _openApiInfo = OpenApiCatalogClient.FindOperation(doc, _descriptor.PathTemplate, _descriptor.Method);
        }
        catch (Exception ex)
        {
            _openApiError = $"Could not load OpenAPI: {ex.Message}";
        }
        finally
        {
            _openApiLoading = false;
            StateHasChanged();
        }
        _ = forceRefresh;
    }

    private static Dictionary<string, string?> SeedValues(ApiEndpointDescriptor d)
    {
        Dictionary<string, string?> seeded = new(StringComparer.OrdinalIgnoreCase);
        foreach (ApiParameter p in d.Parameters)
            seeded[p.Name] = p.DefaultValue;
        return seeded;
    }

    private void OnValueInput(string name, ChangeEventArgs e)
    {
        _values[name] = e.Value?.ToString();
        RebuildPreview();
        _ = PersistValuesAsync();
    }

    private bool GetBool(ApiParameter p) =>
        bool.TryParse(_values.TryGetValue(p.Name, out string? v) ? v : p.DefaultValue, out bool b) && b;

    private void SetBool(ApiParameter p, ChangeEventArgs e)
    {
        bool b = e.Value is bool bv ? bv : bool.TryParse(e.Value?.ToString(), out bool parsed) && parsed;
        _values[p.Name] = b ? "true" : "false";
        RebuildPreview();
        _ = PersistValuesAsync();
    }

    private void RebuildPreview()
    {
        if (_descriptor is null || _selectedEndpoint is null)
        {
            _preview = null;
            _previewError = null;
            return;
        }
        try
        {
            _preview = ApiUrlBuilder.Build(_selectedEndpoint.Address, _descriptor, _values);
            _previewError = null;
        }
        catch (ApiInvocationValidationException ex)
        {
            _preview = null;
            _previewError = $"(missing required: {string.Join(", ", ex.MissingParameters)})";
        }
        catch (Exception ex)
        {
            _preview = null;
            _previewError = ex.Message;
        }
    }

    private async Task OnInvokeClickedAsync()
    {
        if (_descriptor is null) return;
        if (_descriptor.Destructive)
        {
            RebuildPreview();
            if (_preview is null) return;
            _confirmOpen = true;
            return;
        }
        await ExecuteAsync();
    }

    private async Task ConfirmAndExecuteAsync()
    {
        _confirmOpen = false;
        await ExecuteAsync();
    }

    private async Task ExecuteAsync()
    {
        if (_descriptor is null || _selectedEndpoint is null) return;
        _running = true;
        ClearResult();
        StateHasChanged();
        try
        {
            string clientName = string.Equals(SelectedSource, SourceApiCatalog.Orchestrator,
                StringComparison.OrdinalIgnoreCase) ? "orchestrator" : "source-direct";
            _result = await Invoker.InvokeAsync(clientName, _selectedEndpoint.Address, _descriptor, _values);
            if (_result.IsSuccess)
            {
                TryParseSearchHits(_result.ResponseBody);
                TryParseCrossRefHits(_result.ResponseBody);
            }
        }
        catch (ApiInvocationValidationException ex)
        {
            _result = new ApiInvocationResult(_descriptor.PathTemplate, _descriptor.Method, null, 0,
                $"Validation failed: missing {string.Join(", ", ex.MissingParameters)}", 0);
        }
        catch (Exception ex)
        {
            _result = new ApiInvocationResult(_descriptor.PathTemplate, _descriptor.Method, null, 0, ex.ToString(), 0);
        }
        finally
        {
            _running = false;
        }
    }

    private void ClearResult()
    {
        _result = null;
        _parsedResults = null;
        _parsedCrossRefs = null;
        _showRaw = false;
    }

    private void ToggleRaw() => _showRaw = !_showRaw;

    private void TryParseSearchHits(string json)
    {
        if (_descriptor is null) return;
        if (_descriptor.Id is not "content.search" and not "content.refers-to"
            and not "content.referred-by" and not "content.cross-referenced") return;
        try
        {
            using JsonDocument doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("hits", out JsonElement hits)
                && hits.ValueKind == JsonValueKind.Array
                && doc.RootElement.TryGetProperty("values", out _))
            {
                _parsedTotalResults = doc.RootElement.TryGetProperty("total", out JsonElement total) ? total.GetInt32() : hits.GetArrayLength();
                _parsedResults = [];
                foreach (JsonElement r in hits.EnumerateArray())
                {
                    _parsedResults.Add(new ParsedSearchResult(
                        Source: GetStr(r, "source") ?? "",
                        Id: GetStr(r, "id") ?? "",
                        Title: GetStr(r, "title") ?? "",
                        Score: r.TryGetProperty("score", out JsonElement scoreEl) && scoreEl.ValueKind == JsonValueKind.Number ? scoreEl.GetDouble() : 0,
                        Snippet: GetStr(r, "snippet"),
                        Url: GetStr(r, "url")
                    ));
                }
            }
        }
        catch { }
    }

    private void TryParseCrossRefHits(string json)
    {
        if (_descriptor is null) return;
        if (_descriptor.Id is not "content.refers-to" and not "content.referred-by"
            and not "content.cross-referenced") return;
        try
        {
            using JsonDocument doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("hits", out JsonElement hits)
                && hits.ValueKind == JsonValueKind.Array
                && doc.RootElement.TryGetProperty("direction", out _))
            {
                string queriedValue = GetStr(doc.RootElement, "value") ?? "";
                _parsedCrossRefs = [];
                foreach (JsonElement r in hits.EnumerateArray())
                {
                    string sourceType = GetStr(r, "sourceType") ?? "";
                    string sourceId = GetStr(r, "sourceId") ?? "";
                    string targetType = GetStr(r, "targetType") ?? "";
                    string targetId = GetStr(r, "targetId") ?? "";
                    string? targetTitle = GetStr(r, "targetTitle");
                    string? targetUrl = GetStr(r, "targetUrl");

                    bool targetIsQueried = string.Equals(targetId, queriedValue, StringComparison.OrdinalIgnoreCase);
                    string viewType = targetIsQueried ? sourceType : targetType;
                    string viewId = targetIsQueried ? sourceId : targetId;

                    double score = r.TryGetProperty("score", out JsonElement scoreProp) && scoreProp.TryGetDouble(out double s) ? s : 1.0;

                    _parsedCrossRefs.Add(new ParsedCrossRef(
                        SourceType: sourceType,
                        SourceId: sourceId,
                        TargetType: targetType,
                        TargetId: targetId,
                        LinkType: GetStr(r, "linkType") ?? "",
                        Context: GetStr(r, "context"),
                        SourceContentType: GetStr(r, "contentType"),
                        TargetTitle: targetTitle,
                        TargetUrl: targetUrl,
                        Score: score,
                        ViewType: viewType,
                        ViewId: viewId
                    ));
                }
            }
        }
        catch { }
    }

    private static string? GetStr(JsonElement el, string name) =>
        el.TryGetProperty(name, out JsonElement v) && v.ValueKind == JsonValueKind.String ? v.GetString() : null;

    private static string Truncate(string text, int maxLength) =>
        string.IsNullOrEmpty(text) ? "" :
            text.Length <= maxLength ? text : string.Concat(text.AsSpan(0, maxLength), "…");

    private static string ColumnClass(ApiParameter p) =>
        p.ValueType == ApiParameterValueType.Json ? "col-12" :
        p.Kind == ApiParameterKind.Path || p.IsCatchAll ? "col-md-6" : "col-md-3";

    private sealed record SourceEndpointInfo(string Name, string Address);
    private sealed record ParsedSearchResult(string Source, string Id, string Title, double Score, string? Snippet, string? Url);
    private sealed record ParsedCrossRef(string SourceType, string SourceId, string TargetType, string TargetId, string LinkType, string? Context, string? SourceContentType, string? TargetTitle, string? TargetUrl, double Score, string ViewType, string ViewId);
}

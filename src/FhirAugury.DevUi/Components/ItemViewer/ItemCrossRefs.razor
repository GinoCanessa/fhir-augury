@using FhirAugury.Common.Api
@using FhirAugury.DevUi.Services

<div class="row mt-4">
    @* Cross-References *@
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header fw-semibold">
                <i class="bi bi-link-45deg"></i> Cross-References
                @if (CrossRefs?.References is not null)
                {
                    <span class="badge bg-secondary ms-1">@CrossRefs.References.Count</span>
                }
            </div>
            <div class="card-body">
                @if (CrossRefs?.References is { Count: > 0 })
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Target</th>
                                    <th>ID</th>
                                    <th>Link</th>
                                    <th>Title</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (SourceCrossReference xref in CrossRefs.References)
                                {
                                    <tr>
                                        <td><span class="badge @SourceBadgeHelper.SourceBadgeClass(xref.TargetType)">@xref.TargetType</span></td>
                                        <td><a href="@ItemViewerUrl.For(xref.TargetType, xref.TargetId)"><code>@xref.TargetId</code></a></td>
                                        <td><span class="badge bg-primary">@xref.LinkType</span></td>
                                        <td title="@xref.TargetTitle">@Truncate(xref.TargetTitle ?? "", 40)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <span class="text-muted">No cross-references found.</span>
                }
            </div>
        </div>
    </div>

    @* Related Items *@
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-diagram-3"></i> Related Items
                    @if (RelatedItems?.Items is not null)
                    {
                        <span class="badge bg-secondary ms-1">@RelatedItems.Items.Count</span>
                    }
                </span>
                @if (RelatedItems is null && !LoadingRelated)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="OnLoadRelated">
                        <i class="bi bi-search"></i> Load
                    </button>
                }
            </div>
            <div class="card-body">
                @if (LoadingRelated)
                {
                    <div class="text-center py-2">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span class="ms-2 text-muted small">Loading…</span>
                    </div>
                }
                else if (RelatedError is not null)
                {
                    <div class="alert alert-warning small mb-0">@RelatedError</div>
                }
                else if (RelatedItems?.Items is { Count: > 0 })
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Source</th>
                                    <th>ID</th>
                                    <th>Title</th>
                                    <th class="text-end">Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (RelatedItem rel in RelatedItems.Items)
                                {
                                    <tr>
                                        <td><span class="badge @SourceBadgeHelper.SourceBadgeClass(rel.Source)">@rel.Source</span></td>
                                        <td><a href="@ItemViewerUrl.For(rel.Source, rel.Id)"><code>@rel.Id</code></a></td>
                                        <td title="@rel.Title">@Truncate(rel.Title, 40)</td>
                                        <td class="text-end">@rel.RelevanceScore.ToString("F2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (RelatedItems is not null)
                {
                    <span class="text-muted">No related items found.</span>
                }
                else
                {
                    <span class="text-muted small">Click "Load" to fetch related items.</span>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public CrossReferenceResponse? CrossRefs { get; set; }
    [Parameter] public FindRelatedResponse? RelatedItems { get; set; }
    [Parameter] public bool LoadingRelated { get; set; }
    [Parameter] public string? RelatedError { get; set; }
    [Parameter] public EventCallback OnLoadRelated { get; set; }

    private static string Truncate(string text, int maxLength) =>
        string.IsNullOrEmpty(text) ? "" : text.Length <= maxLength ? text : string.Concat(text.AsSpan(0, maxLength), "…");
}

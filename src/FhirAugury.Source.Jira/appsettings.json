{
  "Jira": {
    "BaseUrl": "https://jira.hl7.org",
    "AuthMode": "cookie",
    "CachePath": "./cache/jira",
    "DatabasePath": "./data/jira.db",
    "SyncSchedule": "01:00:00",
    "DefaultProject": "FHIR",
    "Ports": {
      "Http": 5160,
      "Grpc": 5161
    },
    "RateLimiting": {
      "MaxRequestsPerSecond": 10,
      "BackoffBaseSeconds": 2,
      "MaxRetries": 3
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

{
  "Confluence": {
    "BaseUrl": "https://confluence.hl7.org",
    "AuthMode": "cookie",
    "Spaces": [ "FHIR", "FHIRI", "SOA" ],
    "CachePath": "./cache",
    "DatabasePath": "./data/confluence.db",
    "SyncSchedule": "1.00:00:00",
    "MinSyncAge": "04:00:00",
    "Ports": {
      "Http": 5180,
      "Grpc": 5181
    },
    "RateLimiting": {
      "MaxRequestsPerSecond": 5,
      "BackoffBaseSeconds": 2,
      "MaxRetries": 3
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

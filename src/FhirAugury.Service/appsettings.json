{
  "FhirAugury": {
    "DatabasePath": "fhir-augury.db",
    "Sources": {
      "jira": {
        "Enabled": true,
        "SyncSchedule": "01:00:00",
        "BaseUrl": "https://jira.hl7.org",
        "AuthMode": "Cookie",
        "Cookie": null,
        "ApiToken": null,
        "Email": null,
        "DefaultJql": "project = \"FHIR Specification Feedback\""
      },
      "zulip": {
        "Enabled": true,
        "SyncSchedule": "00:30:00",
        "BaseUrl": "https://chat.fhir.org",
        "Email": null,
        "ApiKey": null,
        "CredentialFile": null,
        "OnlyWebPublic": true
      }
    },
    "Bm25": {
      "K1": 1.2,
      "B": 0.75
    },
    "Api": {
      "Port": 5100,
      "CorsOrigins": [ "*" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

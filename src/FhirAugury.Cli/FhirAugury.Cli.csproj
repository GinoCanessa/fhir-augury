<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>FhirAugury.Cli</RootNamespace>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>fhir-augury</ToolCommandName>
    <PackageId>FhirAugury.Cli</PackageId>
    <Description>FHIR Augury — unified knowledge platform CLI for searching HL7 FHIR community data sources.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FhirAugury.Models\FhirAugury.Models.csproj" />
    <ProjectReference Include="..\FhirAugury.Database\FhirAugury.Database.csproj" />
    <ProjectReference Include="..\FhirAugury.Sources.Jira\FhirAugury.Sources.Jira.csproj" />
    <ProjectReference Include="..\FhirAugury.Sources.Zulip\FhirAugury.Sources.Zulip.csproj" />
    <ProjectReference Include="..\FhirAugury.Sources.Confluence\FhirAugury.Sources.Confluence.csproj" />
    <ProjectReference Include="..\FhirAugury.Sources.GitHub\FhirAugury.Sources.GitHub.csproj" />
    <ProjectReference Include="..\FhirAugury.Indexing\FhirAugury.Indexing.csproj" />
  </ItemGroup>

</Project>
